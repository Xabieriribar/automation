# FastAPI Server Config
PORT=8000

# Twilio Credentials (Optional: required only if Twilio "Secure Media" is enabled)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# WhatsApp Demo Settings for Instant Customer Validation
DEBUG_CLIENT_NUMBER=+41780000000
# TWILIO_CONTENT_SID=HX... # (Optional) If you have a predefined Twilio WhatsApp Quick Reply template

# Gemini AI Intermediate Intelligence Layer Config
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# Google Drive Parent Folder ID (ID of the "Garage_Dossiers" folder)
GOOGLE_DRIVE_PARENT_FOLDER_ID=your_google_drive_parent_folder_id_here

# Google Authentication Config
# To bypass the "storageQuotaExceeded" error for personal @gmail.com accounts:
# Use Option A (OAuth 2.0 User Credentials). If you are using Google Workspace with Shared Drives, you can use Option B.

# Option A: Google OAuth 2.0 User Credentials (Acts as your personal account with full quota)
GOOGLE_REFRESH_TOKEN=your_oauth_refresh_token_here
GOOGLE_CLIENT_ID=your_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_oauth_client_secret_here

# Option B: Google Service Account Credentials (Requires Shared Drives on Google Workspace)
# GOOGLE_SERVICE_ACCOUNT_JSON=./credentials.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}

