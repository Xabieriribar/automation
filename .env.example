# FastAPI Server Config
PORT=8000

# Twilio Credentials (Optional: required only if Twilio "Secure Media" is enabled)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Google Drive Parent Folder ID (ID of the "Garage_Dossiers" folder)
GOOGLE_DRIVE_PARENT_FOLDER_ID=your_google_drive_parent_folder_id_here

# Google Service Account Credentials
# You can provide either:
# 1. The relative/absolute path to your JSON credential file:
#    GOOGLE_SERVICE_ACCOUNT_JSON=./credentials.json
# 2. OR the raw JSON string directly (ideal for Vercel/Render/Docker):
#    GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": ...}
GOOGLE_SERVICE_ACCOUNT_JSON=path_or_raw_json_string_here
