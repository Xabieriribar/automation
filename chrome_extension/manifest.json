{
  "manifest_version": 3,
  "name": "Garage Devis Automatique",
  "version": "1.1",
  "description": "Génère un devis professionnel suisse avec marge à partir de votre panier de pièces (Derendinger, Technomag, Oscaro, etc.).",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://automation-dsni.onrender.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "devis-automatique-garage@xabieriribar.ch",
      "strict_min_version": "109.0"
    }
  }
}
